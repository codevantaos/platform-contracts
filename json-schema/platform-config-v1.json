{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Platform Configuration v1",
  "description": "Schema for validating platform configuration files.",
  "type": "object",
  "properties": {
    "environment": {
      "type": "string",
      "enum": ["development", "staging", "production"],
      "description": "Deployment environment."
    },
    "database": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "name": {
          "type": "string"
        }
      },
      "required": ["host", "port", "name"]
    }
  },
  "required": ["environment", "database"]
}
